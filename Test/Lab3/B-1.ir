FUNCTION factorial :
PARAM vm
t0 := #1
vf_res := t0
LABEL label0 :
t1 := vm
t2 := #1
IF t1 > t2 GOTO label1
GOTO label2
LABEL label1 :
t4 := vf_res
t5 := vm
t3 := t4 * t5
vf_res := t3
t7 := vm
t8 := #1
t6 := t7 - t8
vm := t6
GOTO label0
LABEL label2 :
t9 := vf_res
RETURN t9
FUNCTION cal_combiniation :
PARAM vc_base
PARAM vc_num
t13 := vc_base
ARG t13
t11 := CALL factorial
t16 := vc_num
ARG t16
t14 := CALL factorial
t18 := vc_base
t19 := vc_num
t17 := t18 - t19
ARG t17
t15 := CALL factorial
t12 := t14 * t15
t10 := t11 / t12
RETURN t10
FUNCTION cal_permutation :
PARAM vp_base
PARAM vp_num
t23 := vp_base
ARG t23
t21 := CALL factorial
t25 := vp_base
t26 := vp_num
t24 := t25 - t26
ARG t24
t22 := CALL factorial
t20 := t21 / t22
RETURN t20
FUNCTION main :
READ t27
vn := t27
READ t28
vk := t28
t32 := vk
ARG t32
t31 := vn
ARG t31
t30 := CALL cal_combiniation
WRITE t30
t36 := vk
ARG t36
t35 := vn
ARG t35
t34 := CALL cal_permutation
WRITE t34
t37 := #0
RETURN t37
